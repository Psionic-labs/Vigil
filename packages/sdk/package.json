{
  "name": "@vigil/sdk",
  "version": "0.1.0",
  "description": "Vigil tracking SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "rrweb": "2.0.0-alpha.4"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^6.0.3"
  }
}
