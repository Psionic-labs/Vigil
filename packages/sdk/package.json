{
  "name": "@vigil/sdk",
  "version": "0.1.0",
  "description": "Vigil tracking SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "rrweb": "2.0.0-alpha.4"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
