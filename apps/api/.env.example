DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# Rate Limiting & Abuse Protection
INGEST_IP_RPM=120
INGEST_PROJECT_RPM=500
INGEST_SESSION_RPM=30
INGEST_UNKNOWN_PROJECT_RPM=1000
INGEST_BURST_MULTIPLIER=1.5
INGEST_UNKNOWN_PROJECT_BURST_MULTIPLIER=3
KNOWN_PROJECT_CACHE_TTL_MS=60000
RATE_LIMIT_BUCKET_TTL_MS=900000
RATE_LIMIT_MAX_IP_BUCKETS=50000
RATE_LIMIT_MAX_PROJECT_BUCKETS=10000
RATE_LIMIT_MAX_SESSION_BUCKETS=100000
TRUST_PROXY=false
ENABLE_INTERNAL_METRICS=false
# INTERNAL_METRICS_TOKEN=some_secure_shared_secret

OPENROUTER_API_KEY=your_api_key

MOCK_AI="false"